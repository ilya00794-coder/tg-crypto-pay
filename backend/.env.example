# --- 2328.io credentials (from project settings) ---
GATEWAY_BASE_URL=https://api.2328.io/api
GATEWAY_PROJECT_UUID=your-project-uuid
GATEWAY_API_KEY=your-payment-api-key
GATEWAY_PAYOUT_API_KEY=your-payout-api-key
GATEWAY_USER_AGENT=tg-crypto-pay/0.1 (+https://example.com)

# Public URL of THIS backend, used as webhook callback target
PUBLIC_BASE_URL=https://your-tunnel.example.com

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:your-bot-token

# --- App ---
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# Default platform markup (%) added on top of merchant invoices -> your crypto fee
DEFAULT_MARKUP_PERCENT=3
# Comma list: allow these crypto the customer can pay with
SUPPORTED_CRYPTO=USDT,TON,BTC,ETH,TRX
